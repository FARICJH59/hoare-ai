{
  "name": "hoare-ai",
  "version": "1.0.0",
  "description": "Standalone agent runtime powering HOARE tools, quantum compute, multi-agent swarm, chat, execution, and SDK APIs.",
  "main": "dist/api/index.js",
  "types": "dist/api/index.d.ts",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "tsc",
    "build:all": "turbo run build",
    "start": "node dist/api/index.js",
    "dev": "ts-node api/index.ts",
    "test": "jest --passWithNoTests",
    "test:all": "turbo run test",
    "lint": "eslint . --ext .ts --ignore-path .eslintignore",
    "lint:fix": "eslint . --ext .ts --fix --ignore-path .eslintignore",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\" --ignore-path .prettierignore",
    "type-check": "tsc --noEmit",
    "prepare": "node -e \"try{require('husky').install()}catch(e){}\"",
    "clean": "rm -rf dist .turbo"
  },
  "keywords": ["ai", "agent", "swarm", "quantum", "robotics", "ml", "finance", "qgps"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
