{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "agent/**/*",
    "tools/**/*",
    "api/**/*",
    "sdk/node/**/*",
    "packages/**/*",
    "tests/**/*"
  ],
  "exclude": ["node_modules", "dist", "sdk/python", "apps"]
}
