# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Authentication ────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens — set a strong random value in production
JWT_SECRET=change-me-in-production-use-a-32-char-random-string

# Comma-separated list of valid API keys for machine-to-machine auth
API_KEYS=key1,key2
HOARE_API_KEY=key1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=******localhost:5432/hoare_ai

# ── Cache / Queue ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── QGPS Gateway ──────────────────────────────────────────────────────────────
QGPS_BASE_URL=https://qgps.example.com
QGPS_API_KEY=qgps-api-key-here
QGPS_TENANT_ID=your-tenant-id

# ── AI / LLM ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
METRICS_PORT=9090

# ── External search (optional; used by EnergyAgent) ───────────────────────────
WEB_SEARCH_ENDPOINT=https://search.example.com/query
WEB_SEARCH_API_KEY=web-search-api-key
WEB_SEARCH_TRUSTED_HOSTS=grid.example.com,carbon.example.com
ENERGY_ACTIONS_HOURLY_LIMIT=20
ENERGY_ACTIONS_DAILY_LIMIT=100
BILLING_CRON_SECRET=change-me-billing-cron-secret

# ── Next.js (apps/web) ────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-nextauth-secret
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PRICE_ID=price_your-subscription-price-id
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ── Vercel ───────────────────────────────────────────────────────────────────
# Set in GitHub Secrets — do not commit real values
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
