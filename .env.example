# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-here

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Primary LLM (OpenAI-compatible)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/hoareai

# ─── QGPS Control Plane ───────────────────────────────────────────────────────
QGPS_BASE_URL=http://qgps-control-plane/api/v1
QGPS_API_KEY=your-qgps-api-key

# ─── Auth Providers (optional) ────────────────────────────────────────────────
GITHUB_ID=
GITHUB_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=60
RATE_LIMIT_RPH=500

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_QGPS_SUBMISSION=false
ENABLE_STREAMING=true
ENABLE_PROJECT_GENERATION=true

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
